# =============================================================================
# Bee's Perfumery — Production Environment Variables
# Copy this file to .env and fill in your real values BEFORE running Docker.
# NEVER commit .env to version control.
# =============================================================================

# --- Database ---
DB_NAME=bees_perfumery
DB_USER=bees_user
DB_PASSWORD=<generate-a-strong-random-password>

# --- Django ---
SECRET_KEY=<generate-a-long-random-secret-key-via-python3 -c "import secrets; print(secrets.token_urlsafe(50))">
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# --- Paystack (Live Keys) ---
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx

# --- Email (SMTP) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-real-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL="Bee's Perfumery <your-real-email@gmail.com>"

# --- Frontend (Vite build-time) ---
VITE_API_URL=https://yourdomain.com/api/
VITE_PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# --- Google OAuth ---
GOOGLE_CALLBACK_URL=https://yourdomain.com/login/callback
